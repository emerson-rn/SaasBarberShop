# Configurações de Segurança - NÃO COMMITAR
# Adicione este arquivo ao .gitignore se ainda não estiver

# Secret Key do Django - gere uma nova em https://djecrety.ir/
SECRET_KEY=sua-secret-key-aqui

# Debug mode - FALSE em produção!
DEBUG=False

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# Configurações de Email (para produção)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-app